# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ─── Dependencies ───
node_modules/

# ─── Expo ───
.expo/
dist/
web-build/
expo-env.d.ts

# ─── Native ───
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore

# Generated native folders (regenerated by `expo prebuild` / `expo run`)
# Comment these out if you want to commit the native projects.
# /ios
# /android

# Android build artifacts (always ignored)
android/build/
android/app/build/
android/.gradle/
android/.cxx/
android/local.properties

# iOS build artifacts
ios/build/
ios/Pods/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/

# ─── Metro ───
.metro-health-check*

# ─── Debug logs ───
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.log*

# ─── macOS ───
.DS_Store
*.pem

# ─── Secrets & env files (NEVER COMMIT) ───
.env
.env.*
!.env.example
.env*.local

# ─── Firebase / Google service files (contain API keys) ───
google-services.json
google-services*.json
GoogleService-Info.plist
firebase-adminsdk-*.json
service-account*.json

# ─── TypeScript ───
*.tsbuildinfo

# ─── Expo example ───
app-example

# ─── Editor / IDE folders ───
.vscode/
.idea/

# ─── AI assistant / local tool folders ───
.claude/
.claude*
CLAUDE.md
.qwen/
.qwen*
.cursor/
.cursorrules
.github-copilot/
.aider*
.continue/

# ─── Temp / misc ───
*.log
*.txt
tmpclaude-*
tmp*-cwd
